<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{% if title %}{{ title }} | {% endif %}danny-anderson.com</title>
  <meta name="description" content="{{ description or '' }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Rokkitt:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="alternate" type="application/atom+xml" title="Danny Anderson" href="/feed.xml">
</head>
<body class="site-body">

  {% include "navigation.njk" %}

  <div class="jumbotron">
    <div class="container">
      <h1 class="jumbotron-heading">Danny Anderson</h1>
    </div>
  </div>

  <main class="container main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      {% include "social-links.njk" %}
    </div>
  </footer>

  <script src="/js/main.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
